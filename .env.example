APP_NAME=alpaca-paper-agent
APP_ENV=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
TRADING_MODE=paper
ENABLE_STARTUP_BROKER_VALIDATION=true
ENABLE_STREAM_WORKER=true
ENABLE_PAPER_EXECUTION=false
RECONCILE_INTERVAL_SECONDS=60
ALPACA_API_TIMEOUT_SECONDS=10
RISK_MAX_POSITION_NOTIONAL=2500
RISK_MAX_GROSS_EXPOSURE_PCT=1.0
RISK_MAX_NET_EXPOSURE_PCT=1.0
RISK_MAX_OPEN_POSITIONS=10
RISK_MAX_STRATEGY_EXPOSURE_PCT=0.4
RISK_MAX_SYMBOL_EXPOSURE_PCT=0.2
RISK_COOLDOWN_AFTER_EXIT_MINUTES=30
RISK_SIDE_FLIP_COOLDOWN_MINUTES=60
RISK_MAX_DAILY_TURNOVER_PCT=2.0
RISK_DAILY_LOSS_BREAKER_PCT=0.03
RISK_MIN_STOP_DISTANCE_PCT=0.005
RISK_MIN_REWARD_RISK_RATIO=1.5
PORTFOLIO_TOTAL_BUDGET_PCT=1.0
PORTFOLIO_SYMBOL_BUDGET_PCT=0.2
PORTFOLIO_STRATEGY_BUDGET_PCT=0.4
PORTFOLIO_SECTOR_BUCKET_LIMIT=4
STRATEGY_MAX_PROPOSALS_PER_CYCLE=10
EXECUTION_STALE_ORDER_MINUTES=30
# Host-run default when Postgres/Redis are started via `docker compose up -d postgres redis`.
# If you run the API inside Docker Compose too, switch these hosts back to `postgres` and `redis`.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/alpaca_paper_agent
REDIS_URL=redis://localhost:6379/0
ALPACA_API_KEY=your_paper_api_key
ALPACA_API_SECRET=your_paper_api_secret
ALPACA_API_BASE_URL=https://paper-api.alpaca.markets
ALPACA_MARKET_DATA_URL=https://data.alpaca.markets
WATCHLIST=AAPL,MSFT,SPY,QQQ
