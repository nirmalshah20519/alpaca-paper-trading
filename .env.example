# -----------------------------------------------------------
# ALLOWED ENVIRONMENT VARIABLES — Do NOT add extras here.
# All other config lives in config/*.py (version-controlled).
# -----------------------------------------------------------

ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
OPENAI_API_KEY=your_openai_key

# Allowed values: PAPER | REAL
# Default is PAPER. Set to REAL only when you want live trading.
TRADING_MODE=PAPER

# Set to FALSE to use local on-device model (LiquidAI/LFM2.5-1.2B-Thinking)
# Requires GPU/VRAM or significant RAM.
USEGPT=TRUE
